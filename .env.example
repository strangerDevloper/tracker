# Copy this file to `.env` and fill in the values.
# See README.md → "Getting Started" for where each value comes from.

# ----- Supabase Postgres (Prisma) -----
# Pooled connection string (pgbouncer). Used by the app at runtime.
DATABASE_URL=""
# Direct connection string (5432). Used by Prisma Migrate only.
DIRECT_URL=""

# ----- Supabase Auth / client SDK -----
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ----- Transactional email (Resend) -----
RESEND_API_KEY=""

# ----- Error tracking (Sentry) -----
SENTRY_DSN=""

# ----- Cron endpoint shared secret -----
CRON_SECRET=""

# ----- Market data providers -----
ALPHA_VANTAGE_API_KEY=""
COINGECKO_API_KEY=""
